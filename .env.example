# =====================================================
# CRT Scanner — Proxy .env Configuration (OPSIYONEL)
# =====================================================
# Bu dosyayi '.env' olarak kopyala ve doldur. Proxy baslarken otomatik okur.
# Daha guvenli: Sifre/token browser localStorage'da plaintext kalmaz.
#
# Windows PowerShell ile baslat:
#   $env:MT5_PASSWORD="your_pw"; node crt_ai_proxy_server.js
# Veya dotenv kullanmiyorsan, sistem env vars set et.

# --- MT5 Hesap (browser localStorage yerine burada tutmak guvenli) ---
# MT5_LOGIN=12345678
# MT5_PASSWORD=SuperSecret123
# MT5_SERVER=Broker-Demo

# --- Telegram Bot (browser'da token tutmaktan kaciniyorsan) ---
# TELEGRAM_BOT_TOKEN=1234567890:AAH-abc...
# TELEGRAM_CHAT_ID=-1001234567890

# --- Trade & API ---
# ALLOW_REAL_TRADING=false       # Live emir icin true yap (sadece test sonrasi!)
# OPENAI_API_KEY=sk-...          # AI sinyal dogrulama icin
# PORT=8787

# --- Canli / uzaktan erisim (VPS uzerinde) ---
# CRT_LISTEN_HOST=0.0.0.0        # Dis dunyaya acmak icin (varsayilan: 127.0.0.1 sadece yerel)
# CRT_PROXY_TOKEN=uzun-rastgele-bir-parola   # ZORUNLU TAVSIYE: internete acik proxy'yi korur
#                                # Dashboard: localStorage.setItem('crt_proxy_token','...')
#                                # veya Authorization: Bearer <token>

# --- Pathler (default: proje icindeki data/, knowledge/) ---
# CRT_DB_PATH=./data/trade_log.db
# CRT_KNOWLEDGE_DIR=./knowledge
# CRT_DEBUG_LOG=true
# CRT_DEBUG_LOG_PATH=./data/debug.log
# CRT_DEBUG_LOG_MAX_BYTES=5242880   # 5MB
# CRT_DEBUG_LOG_KEEP=3
